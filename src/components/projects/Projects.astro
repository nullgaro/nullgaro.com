---
interface Props { data: any; }
const { data } = Astro.props;
const p = data.projects;
---
<section id="projects" class="section-spacing relative">
  <div class="section-container">
    <!-- Section header -->
    <div class="text-center mb-16" data-animate>
      <h2 class="font-display text-section gradient-text inline-block">{p.title}</h2>
      <p class="mt-3 text-gray-500 dark:text-gray-400">{p.subtitle}</p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">

      <!-- Featured project (spans 2 columns on md+) -->
      <div class="md:col-span-2" data-animate>
        <div class="card group p-6 lg:p-8 relative overflow-hidden">
          <!-- Subtle gradient accent -->
          <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-bl from-accent-400/5 to-transparent rounded-bl-full pointer-events-none"></div>

          <div class="relative flex flex-col lg:flex-row gap-6 lg:gap-10">
            <!-- Project preview: image if available, else terminal -->
            <div class="flex-shrink-0 lg:w-72">
              {p.featured.image ? (
                <div class="rounded-xl overflow-hidden border border-gray-100 dark:border-gray-800">
                  <img src={p.featured.image} alt={p.featured.name} class="w-full h-48 object-cover" />
                </div>
              ) : (
                <div class="bg-gray-50 dark:bg-surface-dark rounded-xl border border-gray-100 dark:border-gray-800 overflow-hidden">
                  <div class="flex items-center gap-1.5 px-3 py-2 border-b border-gray-100 dark:border-gray-800">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-400/70"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-green-400/70"></div>
                    <span class="ml-2 text-[10px] font-mono text-gray-400">terminal</span>
                  </div>
                  <div class="p-4 font-mono text-xs leading-6 text-gray-600 dark:text-gray-300">
                    <div><span class="text-emerald-500">$</span> ghfetch nullgaro</div>
                    <div class="mt-2 text-accent-400 dark:text-accent-200">╭──────────────────╮</div>
                    <div class="text-accent-400 dark:text-accent-200">│ <span class="text-gray-500 dark:text-gray-400">nullgaro</span>         │</div>
                    <div class="text-accent-400 dark:text-accent-200">│ <span class="text-gray-400 dark:text-gray-500">repos: 8</span>        │</div>
                    <div class="text-accent-400 dark:text-accent-200">│ <span class="text-gray-400 dark:text-gray-500">stars: 61</span>       │</div>
                    <div class="text-accent-400 dark:text-accent-200">│ <span class="text-gray-400 dark:text-gray-500">followers: 12</span>   │</div>
                    <div class="text-accent-400 dark:text-accent-200">╰──────────────────╯</div>
                  </div>
                </div>
              )}
            </div>

            <!-- Project info -->
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[10px] font-mono font-medium px-2 py-0.5 rounded-full bg-accent-50 dark:bg-accent-900/30 text-accent-600 dark:text-accent-200 uppercase tracking-wider">Featured</span>
              </div>
              <h3 class="font-display text-xl lg:text-2xl font-semibold mt-2">{p.featured.name}</h3>
              <p class="mt-3 text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{p.featured.description}</p>

              <div class="flex flex-wrap gap-1.5 mt-4">
                {p.featured.tech.map((t: string) => (
                  <span class="tech-badge">{t}</span>
                ))}
              </div>

              <div class="flex gap-3 mt-6">
                {p.featured.liveUrl && (
                  <a href={p.featured.liveUrl} target="_blank" rel="noopener" class="btn-primary text-xs px-4 py-2">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                    {p.viewLive}
                  </a>
                )}
                {p.featured.sourceUrl && (
                  <a href={p.featured.sourceUrl} target="_blank" rel="noopener" class="btn-outline text-xs px-4 py-2">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                    {p.viewCode}
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Regular project cards -->
      {p.list.map((project: any, i: number) => (
        <div data-animate style={`transition-delay: ${(i + 1) * 0.1}s;`}>
          <div class="card group h-full flex flex-col overflow-hidden">
            <!-- Project image -->
            {project.image && (
              <div class="w-full h-40 overflow-hidden flex-shrink-0">
                <img
                  src={project.image}
                  alt={project.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}

            <div class="p-5 flex flex-col flex-1">
              <!-- Project header -->
              <div class="flex items-center justify-between mb-3">
                {!project.image && (
                  <div class="w-9 h-9 rounded-lg bg-gray-50 dark:bg-surface-dark border border-gray-100 dark:border-gray-800 flex items-center justify-center">
                    <svg class="w-4 h-4 text-accent-400 dark:text-accent-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>
                  </div>
                )}
                <div class={`flex items-center gap-2 ${project.image ? 'ml-auto' : ''}`}>
                  {project.liveUrl && (
                    <a href={project.liveUrl} target="_blank" rel="noopener" class="text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors" aria-label={`${p.viewLive}: ${project.name}`}>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                    </a>
                  )}
                  {project.sourceUrl && (
                    <a href={project.sourceUrl} target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" aria-label={`${p.viewCode}: ${project.name}`}>
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                    </a>
                  )}
                </div>
              </div>

              <h3 class="font-display font-semibold text-base">{project.name}</h3>
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 leading-relaxed flex-1">{project.description}</p>

              <div class="flex flex-wrap gap-1.5 mt-4">
                {project.tech.map((t: string) => (
                  <span class="tech-badge">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
