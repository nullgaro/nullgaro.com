---
const { lang, tags } = Astro.props;

const data = lang === 'en'
  ? await import('@data/en.json')
  : await import('@data/es.json');
const blog = data.blog;
---
<aside class="space-y-8">
  <!-- Tags -->
  {tags && tags.length > 0 && (
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">
        <a href={lang === 'en' ? '/en/blog/tags' : '/blog/tags'} class="hover:text-accent-400 dark:hover:text-accent-200 transition-colors">
          Tags
        </a>
      </h3>
      <div class="flex flex-wrap gap-2">
        {(tags as string[]).map((tag: string) => (
          <a
            href={lang === 'en' ? `/en/blog/tags/${tag}` : `/blog/tags/${tag}`}
            class="tech-badge hover:border-accent-400/40 dark:hover:border-accent-200/40 hover:text-accent-400 dark:hover:text-accent-200 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Get to know me -->
  <div>
    <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">{blog.knowme}</h3>
    <ul class="space-y-2">
      <li>
        <a href={lang === 'en' ? '/en/' : '/'} class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" /></svg>
          Portfolio
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/daniel-milenov/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </li>
      <li>
        <a href="https://github.com/nullgaro" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </li>
    </ul>
  </div>

  <!-- Read me on -->
  <div>
    <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">{blog.readme}</h3>
    <ul class="space-y-2">
      <li>
        <a href="https://dev.to/nullgaro" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7.826 10.083a.784.784 0 00-.468-.175h-.701v4.198h.701a.786.786 0 00.469-.175c.155-.117.233-.292.233-.525v-2.798c.001-.233-.079-.408-.234-.525zM19.236 3H4.764C3.791 3 3.002 3.787 3 4.76v14.48C3.002 20.213 3.791 21 4.764 21h14.473c.973 0 1.762-.787 1.764-1.76V4.76C21 3.787 20.209 3 19.236 3zm-9.195 9.414c0 .973-.819 1.763-1.797 1.763H5.622V9.176h2.622c.978 0 1.797.79 1.797 1.763v2.475h-.002zm4.300.997c0 .973-.819 1.763-1.797 1.763H10.22V9.176h2.325c.978 0 1.797.79 1.797 1.763v2.472h-.001zm3.650-3.453h-1.745v1.175h1.06v1.114h-1.06v1.155h1.745v1.146h-2.506V9.176h2.506v1.782z"/></svg>
          Dev.to
        </a>
      </li>
      <li>
        <a href="https://medium.com/@nullgaro" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
          Medium
        </a>
      </li>
    </ul>
  </div>
</aside>
