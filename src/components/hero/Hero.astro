---
interface Props { data: any; }
const { data } = Astro.props;
const h = data.hero;
---
<section id="hero" class="relative min-h-screen flex items-center justify-center section-container pt-24 pb-16">
  <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 w-full">
    <!-- Text content -->
    <div class="flex-1 text-center lg:text-left">
      <!-- Name -->
      <h1 class="mt-4 font-display text-hero gradient-text opacity-0 animate-fade-in-up stagger-1">
        {h.name}
      </h1>

      <!-- Handle -->
      <p class="mt-2 font-mono text-lg text-gray-400 dark:text-gray-500 opacity-0 animate-fade-in-up stagger-2">
        @{h.handle}
      </p>

      <!-- Typing effect -->
      <div class="mt-6 h-8 flex items-center justify-center lg:justify-start opacity-0 animate-fade-in stagger-3">
        <span class="font-mono text-emerald-600 dark:text-emerald-200 text-sm mr-2">&gt;</span>
        <span id="typing-text" class="font-mono text-sm text-gray-600 dark:text-gray-300 cursor-pointer select-none" title="psst..."></span>
        <span id="typing-cursor" class="caret-line-fade ml-0.5 inline-block text-accent-400 dark:text-accent-200">|</span>
      </div>

      <!-- Bio -->
      <p class="mt-6 text-base text-gray-500 dark:text-gray-400 max-w-md mx-auto lg:mx-0 leading-relaxed opacity-0 animate-fade-in-up stagger-4">
        {h.bio}
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap gap-4 justify-center lg:justify-start opacity-0 animate-fade-in-up stagger-5">
        <a href="#projects" class="btn-primary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" /></svg>
          {h.cta}
        </a>
        <a href="https://resume.nullgaro.com/nullgaro/daniel-milenov" target="_blank" rel="noopener" class="btn-outline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          {h.ctaSecondary}
        </a>
      </div>

      <!-- Social links -->
      <div class="mt-8 flex items-center gap-5 justify-center lg:justify-start opacity-0 animate-fade-in stagger-6">
        <a href="https://github.com/nullgaro" target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-900 dark:hover:text-white hover:scale-110 transition-all duration-200" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/daniel-milenov" target="_blank" rel="noopener" class="text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:scale-110 transition-all duration-200" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="mailto:danimilenovvalkov@gmail.com" class="text-gray-400 hover:text-warm-400 dark:hover:text-warm-200 hover:scale-110 transition-all duration-200" aria-label="Email">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        </a>
      </div>
    </div>

    <!-- Avatar / Visual element -->
    <div class="relative opacity-0 animate-fade-in stagger-3">
      <div class="relative w-48 h-48 lg:w-56 lg:h-56">
        <!-- Glow ring -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-accent-400/20 via-emerald-400/20 to-warm-400/20 blur-xl animate-pulse-glow"></div>
        <!-- Avatar border ring -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-accent-400 via-emerald-400 to-warm-400 p-[2px]">
          <div class="w-full h-full rounded-full overflow-hidden animate-float">
            <img src="/avatar.webp" alt="Daniel Milenov" class="w-full h-full object-cover" />
          </div>
        </div>
        <!-- Decorative orbiting dot -->
        <div class="absolute -top-2 -right-2 w-4 h-4 rounded-full bg-accent-400 dark:bg-accent-200 shadow-lg shadow-accent-400/30"></div>
        <div class="absolute -bottom-1 -left-3 w-3 h-3 rounded-full bg-emerald-400 dark:bg-emerald-200 shadow-lg shadow-emerald-400/30"></div>
      </div>
    </div>
  </div>

</section>

<script define:vars={{ roles: h.roles }}>
  let typingTimer = null;

  function initTyping() {
    if (typingTimer !== null) { clearTimeout(typingTimer); typingTimer = null; }
    const el = document.getElementById('typing-text');
    if (!el) return;
    el.textContent = '';
    let roleIdx = 0;
    let charIdx = 0;
    let deleting = false;

    function tick() {
      const role = roles[roleIdx];
      if (!deleting) {
        el.textContent = role.substring(0, charIdx + 1);
        charIdx++;
        if (charIdx === role.length) {
          deleting = true;
          typingTimer = setTimeout(tick, 2000);
          return;
        }
        typingTimer = setTimeout(tick, 80);
      } else {
        el.textContent = role.substring(0, charIdx - 1);
        charIdx--;
        if (charIdx === 0) {
          deleting = false;
          roleIdx = (roleIdx + 1) % roles.length;
          typingTimer = setTimeout(tick, 400);
          return;
        }
        typingTimer = setTimeout(tick, 40);
      }
    }
    typingTimer = setTimeout(tick, 1000);
  }
  // ── Caret easter egg ──────────────────────────────────────────────────────
  const carets = [
    { cls: 'caret-line-fade',  char: '|' },  // smooth fade (default)
    { cls: 'caret-block',      char: '█' },  // solid block, no blink
    { cls: 'caret-line-blink', char: '|' },  // sharp blink
    { cls: 'caret-vscode',     char: '|' },  // VS Code shrink
  ];
  let caretIdx = 0;

  function initCaretEgg() {
    const text = document.getElementById('typing-text');
    const cursor = document.getElementById('typing-cursor');
    if (!text || !cursor) return;
    text.addEventListener('click', () => {
      caretIdx = (caretIdx + 1) % carets.length;
      cursor.className = `${carets[caretIdx].cls} ml-0.5 inline-block text-accent-400 dark:text-accent-200`;
      cursor.textContent = carets[caretIdx].char;
    });
  }

  initTyping();
  initCaretEgg();
  document.addEventListener('astro:after-swap', () => { initTyping(); initCaretEgg(); });
</script>

<style>
  /* Caret animations */
  @keyframes caretFade    { 0%,100%{ opacity:1 } 50%{ opacity:0 } }
  @keyframes caretBlink   { 0%,49%{ opacity:1 } 50%,100%{ opacity:0 } }
  @keyframes caretVscode  { 0%,100%{ transform:scaleY(1); opacity:1 } 45%,55%{ transform:scaleY(0.08); opacity:0.4 } }

  .caret-line-fade  { animation: caretFade  1.2s ease-in-out infinite; }
  .caret-line-blink { animation: caretBlink 1s step-end infinite; }
  .caret-block      { animation: none; font-size: 0.7em; vertical-align: middle; }
  .caret-vscode     { animation: caretVscode 1s ease-in-out infinite; display:inline-block; }
</style>
