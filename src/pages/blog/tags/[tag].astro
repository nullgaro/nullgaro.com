---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogPreview from '../../../components/blog/BlogPreview.astro';
import esData from '@data/es.json';

const lang = 'es';
const blog = esData.blog;

export async function getStaticPaths() {
  const allPosts = await getCollection('blogEs');
  const tags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))];
  return tags.map((tag) => ({ params: { tag }, props: { posts: allPosts } }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const filtered = posts.filter((p) => p.data.tags?.includes(tag));
---
<BlogLayout lang={lang} title={`${blog.tagged} ${tag} — ${blog.title}`}>
  <h2 class="font-display text-2xl font-semibold mb-8">
    {blog.tagged} <span class="text-accent-400 dark:text-accent-200">{tag}</span>
  </h2>
  <ul class="w-full">
    {filtered.map((post) => {
      const pubDate = new Date(post.data.pubDate).toLocaleDateString('es-ES');
      const updDate = post.data.updDate
        ? new Date(post.data.updDate).toLocaleDateString('es-ES')
        : null;
      return (
        <BlogPreview
          url={`/blog/${post.id}`}
          title={post.data.title}
          description={post.data.description}
          pubDate={pubDate}
          updDate={updDate}
          image={post.data.image}
          tags={post.data.tags}
          lang={lang}
        />
      );
    })}
  </ul>
</BlogLayout>
