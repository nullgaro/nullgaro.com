---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import BlogSidebar from '../components/blog/BlogSidebar.astro';
import Author from '../components/blog/Author.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updDate?: Date;
  image?: string;
  tags?: string[];
  lang?: string;
}

const { title: postTitle, description, pubDate, updDate, image, tags, lang = 'es' } = Astro.props;

const data = lang === 'en'
  ? await import('@data/en.json')
  : await import('@data/es.json');

const blogTitle = data.blog.title;
const title = `${blogTitle} — ${postTitle}`;

const pubDateStr = new Date(pubDate).toLocaleDateString(lang === 'en' ? 'en-GB' : 'es-ES');
const updDateStr = updDate ? new Date(updDate).toLocaleDateString(lang === 'en' ? 'en-GB' : 'es-ES') : null;
---
<!doctype html>
<html lang={lang} class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Daniel Milenov" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {image && <meta property="og:image" content={image} />}
  <meta property="og:type" content="article" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <ViewTransitions />
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    })();
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body class="bg-surface-light dark:bg-surface-dark text-gray-900 dark:text-gray-100 transition-colors duration-300">
  <canvas id="constellation-bg" class="fixed inset-0 pointer-events-none z-0 opacity-30 dark:opacity-50"></canvas>

  <Header lang={lang} />

  <main class="relative z-10 pt-24 pb-16">
    <div class="max-w-5xl mx-auto px-6 sm:px-8">
      <!-- Post header image -->
      {image && (
        <div class="w-full h-56 sm:h-72 rounded-2xl overflow-hidden mb-10 border border-[var(--color-border)]"
          style={`background-image: url('${image}'); background-size: cover; background-position: center;`}>
        </div>
      )}

      <div class="flex flex-col lg:flex-row gap-10">
        <!-- Article content -->
        <div class="flex-1 min-w-0">
          <!-- Back link -->
          <a
            href={lang === 'en' ? '/en/blog' : '/blog'}
            class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-accent-400 dark:hover:text-accent-200 transition-colors mb-6 font-mono"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
            {data.blog.postheader.home.title}
          </a>

          <h1 class="font-display text-3xl sm:text-4xl font-semibold mb-4 leading-tight">{postTitle}</h1>

          <Author lang={lang} pubDate={pubDateStr} updDate={updDateStr} />

          <!-- Tags -->
          {tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8">
              {tags.map((tag: string) => (
                <a
                  href={lang === 'en' ? `/en/blog/tags/${tag}` : `/blog/tags/${tag}`}
                  class="tech-badge hover:border-accent-400/40 dark:hover:border-accent-200/40 hover:text-accent-400 dark:hover:text-accent-200 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}

          <!-- Article body -->
          <article class="prose-nullgaro">
            <slot />
          </article>
        </div>

        <!-- Sidebar -->
        <div class="lg:w-60 flex-shrink-0">
          <BlogSidebar lang={lang} tags={tags} />
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />

  <style is:global>
    /* Article prose styles using the new design's palette */
    .prose-nullgaro h1,
    .prose-nullgaro h2,
    .prose-nullgaro h3,
    .prose-nullgaro h4 {
      font-family: 'Clash Display', 'Space Grotesk', sans-serif;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: var(--color-text);
    }
    .prose-nullgaro h1 { font-size: 1.875rem; line-height: 1.25; }
    .prose-nullgaro h2 { font-size: 1.5rem; line-height: 1.3; border-bottom: 1px solid var(--color-border); padding-bottom: 0.4rem; }
    .prose-nullgaro h3 { font-size: 1.25rem; }
    .prose-nullgaro h4 { font-size: 1.1rem; }

    .prose-nullgaro p { margin-bottom: 1rem; line-height: 1.75; color: var(--color-text-muted); }
    .prose-nullgaro a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
    .prose-nullgaro a:hover { color: var(--color-accent-hover); }
    .prose-nullgaro ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
    .prose-nullgaro ol { list-style: decimal; padding-left: 1.5rem; margin-bottom: 1rem; }
    .prose-nullgaro li { margin-bottom: 0.25rem; color: var(--color-text-muted); line-height: 1.7; }
    .prose-nullgaro code:not(pre code) {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 0.1em 0.4em;
      color: var(--color-accent);
    }
    .prose-nullgaro pre {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      overflow-x: auto;
      margin-bottom: 1.25rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.875rem;
      line-height: 1.7;
    }
    .prose-nullgaro pre code { background: none; border: none; padding: 0; color: inherit; }
    .prose-nullgaro blockquote {
      border-left: 3px solid var(--color-accent);
      padding-left: 1rem;
      margin: 1.5rem 0;
      color: var(--color-text-muted);
      font-style: italic;
    }
    .prose-nullgaro img { border-radius: 12px; max-width: 100%; height: auto; margin: 1.5rem 0; border: 1px solid var(--color-border); }
    .prose-nullgaro iframe { border-radius: 12px; max-width: 100%; margin: 1.5rem 0; }
    .prose-nullgaro hr { border-color: var(--color-border); margin: 2rem 0; }
    .prose-nullgaro strong { color: var(--color-text); font-weight: 600; }
  </style>

  <script>
    function initConstellation() {
      const canvas = document.getElementById('constellation-bg') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      let animationId: number;
      const particles: { x: number; y: number; vx: number; vy: number; r: number }[] = [];
      const maxDist = 120;
      const particleCount = Math.min(60, Math.floor(window.innerWidth / 20));
      function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight * 3; }
      function createParticles() {
        particles.length = 0;
        for (let i = 0; i < particleCount; i++) {
          particles.push({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, vx: (Math.random() - 0.5) * 0.3, vy: (Math.random() - 0.5) * 0.3, r: Math.random() * 1.5 + 0.5 });
        }
      }
      function draw() {
        ctx!.clearRect(0, 0, canvas.width, canvas.height);
        const isDark = document.documentElement.classList.contains('dark');
        const dotColor = isDark ? 'rgba(127,119,221,' : 'rgba(83,74,183,';
        for (let i = 0; i < particles.length; i++) {
          const p = particles[i];
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
          if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
          ctx!.beginPath(); ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx!.fillStyle = dotColor + '0.6)'; ctx!.fill();
          for (let j = i + 1; j < particles.length; j++) {
            const p2 = particles[j];
            const dx = p.x - p2.x, dy = p.y - p2.y, dist = Math.sqrt(dx*dx + dy*dy);
            if (dist < maxDist) {
              ctx!.beginPath(); ctx!.moveTo(p.x, p.y); ctx!.lineTo(p2.x, p2.y);
              ctx!.strokeStyle = dotColor + (0.15 * (1 - dist / maxDist)) + ')';
              ctx!.lineWidth = 0.5; ctx!.stroke();
            }
          }
        }
        animationId = requestAnimationFrame(draw);
      }
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { canvas.style.display = 'none'; return; }
      resize(); createParticles(); draw();
      window.addEventListener('resize', () => { cancelAnimationFrame(animationId); resize(); createParticles(); draw(); });
    }
    initConstellation();
    document.addEventListener('astro:after-swap', initConstellation);
  </script>
</body>
</html>
